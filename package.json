{
	"name": "miseflow",
	"version": "1.0.5",
	"description": "Plan meals, generate grocery lists, and view recipe notes as interactive cards.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"deploy": "node scripts/deploy-test.mjs",
		"deploy:prod": "mkdir -p \"/home/atommasi/Documents/Obsidian Vault/.obsidian/plugins/$npm_package_name\" && cp main.js manifest.json styles.css \"/home/atommasi/Documents/Obsidian Vault/.obsidian/plugins/$npm_package_name/\"",
		"build:deploy": "npm run build && npm run deploy",
		"build:deploy:prod": "npm run build && npm run deploy:prod",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [],
	"license": "GPL-3.0-or-later",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"@eslint/js": "9.30.1",
		"jiti": "2.6.1"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}